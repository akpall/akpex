{
  "id": "flatcar",
  "name": "Flatcar Linux",
  "boot": {
    "kernel": "/assets/flatcar/current/flatcar_production_pxe.vmlinuz",
    "initrd": [
      "/assets/flatcar/current/flatcar_production_pxe_image.cpio.gz"
    ],
    "args": [
      "initrd=flatcar_production_pxe_image.cpio.gz",
      "flatcar.config.url=http://192.168.100.254:8080/ignition?uuid=${uuid}&mac=${mac:hexhyp}",
      "flatcar.first_boot=yes",
      "flatcar.autologin"
    ]
  },
  "ignition_id": "flatcar.ign"
}
